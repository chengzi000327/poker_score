.manual-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx 24rpx 60rpx;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx 0;
  gap: 12rpx;
}

.title-icon {
  font-size: 36rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.section-body {
  padding: 20rpx 30rpx 28rpx;
}

.body-text {
  font-size: 28rpx;
  color: #4e5969;
  line-height: 1.8;
}

/* 快速开始 - 步骤 */
.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-num {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff6a00, #ff9f43);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
}

.step-text {
  font-size: 28rpx;
  color: #4e5969;
  line-height: 44rpx;
}

/* 记分规则 */
.rule-group {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rule-group:last-child {
  border-bottom: none;
}

.rule-group-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 6rpx;
}

.rule-desc {
  display: block;
  font-size: 26rpx;
  color: #86909c;
  line-height: 1.6;
}

.rule-divider {
  height: 1rpx;
  background: #ff6a00;
  opacity: 0.2;
  margin: 12rpx 0;
}

/* 举例说明 */
.example-box {
  margin-top: 16rpx;
  background: #fff7f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #ff6a00;
}

.example-line {
  display: block;
  font-size: 26rpx;
  color: #4e5969;
  line-height: 1.8;
}

.example-divider {
  height: 1rpx;
  background: #ffd6b0;
  margin: 12rpx 0;
}

.example-total {
  font-weight: 700;
  color: #ff6a00;
  font-size: 28rpx;
}

/* 常见问题 */
.faq-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 8rpx;
}

.faq-a {
  display: block;
  font-size: 26rpx;
  color: #86909c;
  line-height: 1.7;
}

/* 底部 */
.manual-footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.manual-footer .footer-text {
  font-size: 24rpx;
  color: #c0c4cc;
}
