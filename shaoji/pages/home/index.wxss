.home-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 0 36rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ========== 个人资料卡 ========== */
.profile-card {
  width: 100%;
  margin-top: 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  margin-bottom: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar.placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f2f3f5;
  border: 1rpx solid #dcdfe6;
}

.nick-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
  margin-bottom: 24rpx;
}

.stats-row {
  width: 100%;
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background: #f7f8fa;
  border-radius: 16rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2329;
  line-height: 1.2;
}

.stat-value.stat-win { color: #00b42a; }
.stat-value.stat-lose { color: #f53f3f; }

.stat-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.rate {
  color: #ff6a00;
  font-weight: 600;
  font-size: 26rpx;
}

.history-link {
  color: #999;
  font-size: 24rpx;
}

/* ========== 操作按钮 ========== */
.action-row {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.action-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  margin: 0;
  padding: 0;
  letter-spacing: 2rpx;
}
.action-btn::after { display: none; }

.action-btn.start {
  background: linear-gradient(135deg, #ff6a00, #ff9a40);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 106, 0, 0.3);
}
.action-btn.start:active {
  opacity: 0.85;
}

.action-btn.join {
  background: #fff;
  color: #ff6a00;
  border: 3rpx solid #ff6a00;
  box-shadow: 0 4rpx 16rpx rgba(255, 106, 0, 0.1);
}
.action-btn.join:active {
  background: #fff7f0;
}

/* ========== 底部工具栏 ========== */
.footer-row {
  width: 100%;
  margin-top: 36rpx;
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  background: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  font-weight: 500;
}
.footer-btn::after { display: none; }
.footer-btn:active {
  background: #f7f8fa;
}
