<view class="page">
  <view class="section-card">
    <view class="section-title">用户列表</view>
    <block wx:if="{{users.length === 0}}">
      <text class="tip">暂无用户，请先去登录页创建用户。</text>
    </block>

    <view wx:for="{{users}}" wx:key="id" class="user-card">
      <view class="top-row">
        <view class="left">
          <button class="avatar-btn" open-type="chooseAvatar" data-idx="{{index}}" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{item.avatarUrl}}" class="avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
            <view wx:else class="avatar-placeholder"></view>
          </button>
          <view>
            <view wx:if="{{item.id === currentUserId}}" class="current-tag">当前用户</view>
            <input
              class="name-input"
              placeholder="请输入昵称"
              value="{{item.nickName}}"
              data-idx="{{index}}"
              bindinput="onNickNameInput"
            />
          </view>
        </view>
      </view>

      <view class="button-row">
        <button class="mini-btn primary" data-id="{{item.id}}" bindtap="onSaveUser">保存</button>
        <button class="mini-btn" data-id="{{item.id}}" bindtap="onSetCurrent">设为当前</button>
        <button class="mini-btn danger" data-id="{{item.id}}" bindtap="onDeleteUser">删除</button>
      </view>
    </view>
  </view>
</view>
